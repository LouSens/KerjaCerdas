# ─── KerjaCerdas .gitignore ───────────────────────────────────────────────────

# Environment & Secrets (RULE-01)
.env
*.env.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Jupyter
.ipynb_checkpoints/

# ML Models (NEVER commit model weights - PROTOCOL §6)
models/*.pt
models/*.onnx
models/*.bin
*.h5

# Data (versioned via DVC, not git)
data/raw/
data/processed/
data/features/
data/seed/
# Dev JSON store contents (keep folders, ignore records)
data/users/*.json
data/seekers/*.json
data/employers/*.json
data/jobs/*.json
data/applications/*.json
data/matches/*.json
data/embeddings/*.json
data/conversations/*.json
data/skill_gaps/*.json
data/courses/*.json

# Reports (generated output)
reports/

# MLflow
mlruns/

# Node (frontend)
node_modules/
.next/
frontend/dist/

# Docker
*.log

# OS
.DS_Store
Thumbs.db

# Agents config (local)
.agents/
.claude/
frontend/node_modules