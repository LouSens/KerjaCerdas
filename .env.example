# KerjaCerdas — environment variables
# Copy to .env and fill in real values.
# RULE-01: Never commit .env to git.

# ── Google Gemini / Vertex AI ────────────────────────────────────────────────
# Pick ONE auth path:
#  (a) Gemini AI Studio — set GEMINI_API_KEY (https://aistudio.google.com/apikey)
#  (b) Vertex AI        — set VERTEX_AI_PROJECT + VERTEX_AI_LOCATION
#                          and authenticate with `gcloud auth application-default login`
#                          OR set GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
GEMINI_API_KEY=
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1

# Models — Gemini 3.1 Flash Lite for chat/parsing, Gemini Embedding 2 (= gemini-embedding-001) for vectors
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_EMBED_MODEL=gemini-embedding-001
# Output dim — Gemini Embedding 2 supports 768/1536/3072 via Matryoshka truncation
GEMINI_EMBED_DIM=3072

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ─────────────────────────────────────────────────────────────────
# Dev: leave blank → auto SQLite under data/
# Prod: postgresql+asyncpg://user:pass@host:5432/kerjacerdas
DATABASE_URL=

# ── Data storage root (dev JSON store) ───────────────────────────────────────
# Where JSON files are written. Default: data/ next to project root.
KERJA_DATA_ROOT=data

# ── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000

# ── Matching tuning ───────────────────────────────────────────────────────────
MATCHING_TOP_K=10
MATCHING_REGION_WEIGHT=0.10
MATCHING_SALARY_WEIGHT=0.05
MATCHING_SKILL_WEIGHT=0.30
MATCHING_COSINE_WEIGHT=0.50

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
